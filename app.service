[Unit]
Description=Catty Reminders FastAPI service
After=network.target

[Service]
Type=simple
User=artem
Group=artem
WorkingDirectory=/home/artem/dev/catty-reminders-app
EnvironmentFile=/home/artem/dev/catty-reminders-app/.env
ExecStart=/home/artem/dev/catty-reminders-app/venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8181
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
