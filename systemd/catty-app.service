[Unit]
Description=Catty Reminders App
After=network.target

[Service]
User=anm
WorkingDirectory=/home/anm/DevOps/catty-reminders-app
EnvironmentFile=-/home/anm/DevOps/catty-reminders-app/.env.deploy
ExecStart=/home/anm/DevOps/catty-reminders-app/venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8181
Restart=always
RestartSec=2

[Install]
WantedBy=multi-user.target
