[Unit]
Description=Catty Reminders Application
After=network.target

[Service]
User=vboxuser
WorkingDirectory=/home/vboxuser/Desktop/devops/catty-reminders-app
Environment="PYTHONPATH=/home/vboxuser/Desktop/devops/catty-reminders-app"

ExecStart=/home/vboxuser/Desktop/devops/venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8181
Restart=always

[Install]
WantedBy=multi-user.target
