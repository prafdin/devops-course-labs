[Unit]
Description=Catty reminders app
After=network.target

[Service]
User=semen
WorkingDirectory=/home/semen/catty-reminders-app
EnvironmentFile=/home/semen/catty-app-env
ExecStart=/home/semen/catty-reminders-app/venv/bin/python -m uvicorn app.main:app --host 0.0.0.0 --port 8181
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
