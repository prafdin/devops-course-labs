[Unit]
Description=Catty Reminders Application
After=network.target

[Service]
# Твой текущий пользователь из терминала
User=ilya
# ПРАВИЛЬНЫЙ ПУТЬ К ПАПКЕ
WorkingDirectory=/home/ilya/catty-reminders-app
EnvironmentFile=/etc/catty-app-env
# ПРАВИЛЬНЫЙ ПУТЬ К ПИТОНУ ВНУТРИ VENV
ExecStart=/home/ilya/catty-reminders-app/venv/bin/python -m uvicorn app.main:app --host 0.0.0.0 --port 8181
Restart=always

[Install]
WantedBy=multi-user.target
