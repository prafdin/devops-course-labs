[Unit]
Description=Catty Reminders App
After=network.target

[Service]
User=vano
WorkingDirectory=/home/vano/catty-app
EnvironmentFile=/tmp/deploy_ref.txt
ExecStart=/home/vano/catty-app/venv/bin/python -m uvicorn app.main:app --host 0.0.0.0 --port 8181
Restart=always

[Install]
WantedBy=multi-user.target
