[Unit]
Description=Catty Reminders App
After=network.target

[Service]
Type=simple
User=kirill
WorkingDirectory=/home/kirill/desktop/devops
EnvironmentFile=/home/kirill/desktop/devops/.env.deploy
Environment="PATH=/home/kirill/desktop/devops/.venv/bin:/usr/bin:/bin"
ExecStart=/home/kirill/desktop/devops/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8181
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
