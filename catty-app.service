[Unit]
Description=Catty Reminders App
After=network.target

[Service]
Type=simple
User=yaroslav
WorkingDirectory=/home/yaroslav/devops-lab/catty-reminders-app
Environment="PATH=/home/yaroslav/devops-lab/catty-reminders-app/venv/bin"
EnvironmentFile=/home/yaroslav/devops-lab/catty-reminders-app/.env
ExecStart=/home/yaroslav/devops-lab/catty-reminders-app/start-app.sh
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
