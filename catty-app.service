[Unit]
Description=Catty Reminders App
After=network.target

[Service]
Type=simple
WorkingDirectory=/home/nightainted/catty-reminders-app
ExecStart=/home/nightainted/catty-reminders-app/venv/bin/python -m uvicorn app.main:app --host 0.0.0.0 --port 8181
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
