[Unit]
Description=Catty FastAPI App
After=network.target

[Service]
Type=simple
User=aleksandr
WorkingDirectory=/home/aleksandr/catty-reminders-app
Environment=/etc/catty-app-env
ExecStart=/home/aleksandr/catty-reminders-app/venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8181
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
