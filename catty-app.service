[Unit]
Description=Catty Reminders Application
After=network.target

[Service]
User=dima
WorkingDirectory=/home/dima/devops/catty-reminders-app
Environment="PYTHONPATH=/home/dima/devops/catty-reminders-app"
#EnvironmentFile=/home/dima/devops/catty-reminders-app/.env
ExecStart=/home/dima/devops/venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8181
Restart=always

[Install]
WantedBy=multi-user.target
