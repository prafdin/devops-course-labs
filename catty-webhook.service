[Unit]
Description=Catty Webhook Handler
After=network.target

[Service]
Type=simple
User=aleksandr
WorkingDirectory=/home/aleksandr/catty-reminders-app
Environment="PATH=/home/aleksandr/catty-reminders-app/venv/bin"
ExecStart=/home/aleksandr/catty-reminders-app/venv/bin/python /home/aleksandr/catty-reminders-app/webhook_handler.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
